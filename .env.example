# ─────────────────────────────────────────────────────────────────────────────
# Auth0 Regular Web Application
# ─────────────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=YOUR_TENANT.auth0.com
AUTH0_CLIENT_ID=YOUR_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_CLIENT_SECRET

# Callback URL registered in Auth0 app settings
# Local dev example: http://localhost:3005/callback
AUTH0_BASE_URL=http://localhost:3005

# Long random string for session cookie encryption
SESSION_SECRET=change_me_to_a_long_random_string

# ─────────────────────────────────────────────────────────────────────────────
# Auth0 Custom API (for issuing proper JWT access tokens + refresh tokens)
# Create at: Auth0 Dashboard -> Applications -> APIs -> Create API
# Enable "Allow Offline Access" on this API.
# ─────────────────────────────────────────────────────────────────────────────
AUTH0_AUDIENCE=https://YOUR_API_IDENTIFIER

# ─────────────────────────────────────────────────────────────────────────────
# Auth0 My Account API — used for Connected Accounts flow
# Identifier format: https://{YOUR_AUTH0_DOMAIN}/me/
# ─────────────────────────────────────────────────────────────────────────────
AUTH0_MY_ACCOUNT_AUDIENCE=https://YOUR_TENANT.auth0.com/me/

# ─────────────────────────────────────────────────────────────────────────────
# GitHub Connection Name in Auth0
# ─────────────────────────────────────────────────────────────────────────────
AUTH0_GITHUB_CONNECTION=github

# ─────────────────────────────────────────────────────────────────────────────
# GitHub Workflow Target
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_REPO_OWNER=your_github_username_or_org
GITHUB_REPO_NAME=your_repo_name
GITHUB_WORKFLOW_ID=checkmate.yml

# App port
PORT=3005

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL (docker-compose / external)
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=checkmate
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=checkmate
POSTGRES_PORT=5432

# For external Postgres, set DATABASE_URL directly (overrides above)
DATABASE_URL=postgres://username:password@host:5432/checkmate
DATABASE_SSL=false

# ─────────────────────────────────────────────────────────────────────────────
# Microsoft Foundry LLM (AI Agent)
# ─────────────────────────────────────────────────────────────────────────────
FOUNDRY_TARGET_URI=https://your_foundry_endpoint.azure.com/api/projects/your_project/openai/v1/responses
FOUNDRY_API_KEY=your_foundry_api_key
FOUNDRY_DEPLOYMENT=your_foundry_deployment
FOUNDRY_API_VERSION=2026-03-05

# ─────────────────────────────────────────────────────────────────────────────
# JIRA / Atlassian via Auth0 Token Vault
# ─────────────────────────────────────────────────────────────────────────────
AUTH0_JIRA_CONNECTION=atlassian
AUTH0_JIRA_SCOPES=read:jira-work write:jira-work read:me offline_access

# Confluence can reuse the same Atlassian connection as JIRA
AUTH0_CONFLUENCE_CONNECTION=atlassian
AUTH0_CONFLUENCE_SCOPES=read:space:confluence read:page:confluence write:page:confluence read:me offline_access
CONFLUENCE_SITE_URL=https://your-org.atlassian.net
CONFLUENCE_SPACE_ID=your_space_id

# Microsoft Teams / Graph via Auth0 Token Vault
AUTH0_TEAMS_CONNECTION=microsoft-teams
AUTH0_TEAMS_SCOPES=User.Read Team.ReadBasic.All Channel.ReadBasic.All ChannelMessage.Send offline_access email openid profile
TEAMS_DEFAULT_TEAM_ID=your_team_id
TEAMS_DEFAULT_CHANNEL_ID=your_channel_id

# ─────────────────────────────────────────────────────────────────────────────
# Legacy direct-Atlassian settings (optional / backwards compatibility)
# ─────────────────────────────────────────────────────────────────────────────
ATLASSIAN_REDIRECT_URI=http://localhost:3005/connect/jira/complete
ATLASSIAN_AUDIENCE=api.atlassian.com
ATLASSIAN_SCOPES=read:jira-work write:jira-work read:me offline_access
JIRA_SITE_URL=https://your-org.atlassian.net
JIRA_PROJECT_KEY=YOUR_PROJECT_KEY
JIRA_ISSUE_TYPE=Task

# ─────────────────────────────────────────────────────────────────────────────
# GitHub Webhook (POST /webhooks/github)
# ─────────────────────────────────────────────────────────────────────────────
# Random secret shared between GitHub and this server for HMAC-SHA256 signature
# verification. Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=change_me_with_random_hex_secret
